# Bot token: Developer Portal → Your App → Bot → Reset Token / Token (NOT Public Key from General Information)
BOT_TOKEN=

# Server (guild) ID: Discord → Server Settings → Widget → Server ID (enable Developer Mode, right-click server → Copy Server ID)
GUILD_ID=

# Channel for scheduled reminders (@everyone): right-click channel → Copy Channel ID
REMINDER_CHANNEL_ID=

# Channel for welcome messages when a member joins (same way to copy ID)
WELCOME_CHANNEL_ID=

# Class roles: log channel ("nick" — "role") and Discord role IDs (right-click role → Copy ID)
CLASS_LOG_CHANNEL_ID=
ROLE_TANK_ID=
ROLE_HEALER_ID=
ROLE_DAMAGER_ID=
