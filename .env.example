# Bot token: Developer Portal → Your App → Bot → Reset Token / Token (NOT Public Key from General Information)
BOT_TOKEN=

# Server (guild) ID: Discord → Server Settings → Widget → Server ID (enable Developer Mode, right-click server → Copy Server ID)
GUILD_ID=

# Channel for scheduled reminders (@everyone) and boss raid polls: right-click channel → Copy Channel ID
REMINDER_CHANNEL_ID=

# Channel for welcome messages when a member joins (same way to copy ID)
WELCOME_CHANNEL_ID=

# (Optional) Channel for posting the list of voters after boss raid polls close
VOTERS_CHANNEL_ID=

# Class roles: log channel ("nick" — "role") and Discord role IDs (right-click role → Copy ID)
CLASS_LOG_CHANNEL_ID=
ROLE_TANK_ID=
ROLE_HEALER_ID=
ROLE_DAMAGER_ID=
# "Guild Friend" role — alternative to game classes for non-member participants
GUILD_FRIEND_ROLE_ID=
# Через запятую: ID ролей модераторов/админов — только лог, без смены игровых ролей
CLASS_PROTECTED_ROLE_IDS=
# Опционально: user ID через запятую. Владелец сервера учитывается автоматически (роль оунера в .env не нужна)
CLASS_PROTECTED_USER_IDS=

# Сводка по классам: json (по умолчанию) = по class-user-messages.json (classKind); roles = по ролям на сервере
CLASS_STATS_SOURCE=json
# Только для CLASS_STATS_SOURCE=roles: не считать ботов (true/1)
CLASS_STATS_EXCLUDE_BOTS=
